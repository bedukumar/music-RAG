# =============================================================================
# RagPipe - Audio RAG Data Ingestion Platform Configuration
# =============================================================================
# Copy this file to .env and modify the values as needed.
# All values shown are defaults.

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
RAGPIPE_APP_NAME=ragpipe
RAGPIPE_ENV=development
RAGPIPE_DEBUG=true
RAGPIPE_HOST=0.0.0.0
RAGPIPE_PORT=8000
RAGPIPE_WORKERS=1
RAGPIPE_LOG_LEVEL=INFO
RAGPIPE_SECRET_KEY=change-me-in-production

# -----------------------------------------------------------------------------
# Database (SQLAlchemy)
# -----------------------------------------------------------------------------
# SQLite (local development)
RAGPIPE_DATABASE_URL=sqlite+aiosqlite:///./data/ragpipe.db
# PostgreSQL (production)
# RAGPIPE_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ragpipe
RAGPIPE_DB_POOL_SIZE=5
RAGPIPE_DB_MAX_OVERFLOW=10
RAGPIPE_DB_POOL_RECYCLE=3600

# -----------------------------------------------------------------------------
# Vector Database (Qdrant)
# -----------------------------------------------------------------------------
RAGPIPE_QDRANT_URL=http://localhost:6333
RAGPIPE_QDRANT_API_KEY=
RAGPIPE_QDRANT_GRPC_PORT=6334
RAGPIPE_QDRANT_PREFER_GRPC=false
RAGPIPE_QDRANT_TIMEOUT=30

# -----------------------------------------------------------------------------
# File Storage
# -----------------------------------------------------------------------------
RAGPIPE_STORAGE_BASE_PATH=./data/storage
RAGPIPE_AUDIO_STORAGE_PATH=./data/storage/audio
RAGPIPE_TRANSCRIPT_STORAGE_PATH=./data/storage/transcripts
RAGPIPE_MAX_AUDIO_SIZE_MB=500

# -----------------------------------------------------------------------------
# Audio Embedding (LAION CLAP)
# -----------------------------------------------------------------------------
RAGPIPE_AUDIO_EMBEDDING_MODEL=laion-clap
RAGPIPE_AUDIO_EMBEDDING_VERSION=v1
RAGPIPE_AUDIO_EMBEDDING_DIMENSION=512
RAGPIPE_AUDIO_SAMPLE_RATE=48000
RAGPIPE_CLAP_ENABLE_FUSION=false
RAGPIPE_CLAP_CHECKPOINT_PATH=

# -----------------------------------------------------------------------------
# Text Embedding (Sentence Transformers)
# -----------------------------------------------------------------------------
RAGPIPE_TEXT_EMBEDDING_MODEL=all-MiniLM-L6-v2
RAGPIPE_TEXT_EMBEDDING_VERSION=v1
RAGPIPE_TEXT_EMBEDDING_DIMENSION=384
RAGPIPE_TEXT_EMBEDDING_BATCH_SIZE=32

# -----------------------------------------------------------------------------
# Audio Chunking
# -----------------------------------------------------------------------------
RAGPIPE_AUDIO_CHUNK_DURATION=30.0
RAGPIPE_AUDIO_CHUNK_OVERLAP=5.0
RAGPIPE_AUDIO_CHUNKING_STRATEGY=fixed_duration
RAGPIPE_AUDIO_CHUNKING_VERSION=v1

# -----------------------------------------------------------------------------
# Text Chunking
# -----------------------------------------------------------------------------
RAGPIPE_TEXT_CHUNK_SIZE=512
RAGPIPE_TEXT_CHUNK_OVERLAP=50
RAGPIPE_TEXT_CHUNKING_STRATEGY=sentence
RAGPIPE_TEXT_CHUNKING_VERSION=v1

# -----------------------------------------------------------------------------
# Metadata
# -----------------------------------------------------------------------------
RAGPIPE_METADATA_FIELDS=title,artist,album,genre,tags,language,description
RAGPIPE_METADATA_TEMPLATE="{title} by {artist}. Album: {album}. Genre: {genre}. Tags: {tags}. Language: {language}. {description}"
RAGPIPE_METADATA_CHUNKING_VERSION=v1

# -----------------------------------------------------------------------------
# Pipeline
# -----------------------------------------------------------------------------
RAGPIPE_PIPELINE_MAX_RETRIES=3
RAGPIPE_PIPELINE_RETRY_DELAY=5
RAGPIPE_PIPELINE_WORKER_COUNT=4
RAGPIPE_PIPELINE_BATCH_SIZE=10
RAGPIPE_PIPELINE_VERSION=v1

# -----------------------------------------------------------------------------
# Locking
# -----------------------------------------------------------------------------
RAGPIPE_LOCK_TTL_SECONDS=300
RAGPIPE_LOCK_RETRY_DELAY=1.0

# -----------------------------------------------------------------------------
# Metrics
# -----------------------------------------------------------------------------
RAGPIPE_METRICS_ENABLED=true
RAGPIPE_METRICS_PORT=9090
RAGPIPE_METRICS_PREFIX=ragpipe

# -----------------------------------------------------------------------------
# Use Mock Embedders (for development/testing without GPU)
# -----------------------------------------------------------------------------
RAGPIPE_USE_MOCK_EMBEDDERS=true
